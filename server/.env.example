# Server env — copy to `server/.env`. Mirrors the root .env.example. The game
# runs fully on mocks with NONE of these set; add keys per service as you go.

PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# Gemini — gamemaster narration + word judging + winner image-gen.
# Default path: the plain Developer API (a bare key from aistudio.google.com).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
STUB_IMAGE_GEN=true
# Alternate path: Vertex AI / "Gemini Enterprise Agent Platform" — bills
# through normal Cloud credits instead of the Developer API's separate prepay
# wallet. Set GEMINI_USE_VERTEX=true + GEMINI_VERTEX_PROJECT and leave
# GEMINI_API_KEY empty; auth is via Application Default Credentials, not a key
# — run `gcloud auth application-default login`, or set
# GOOGLE_APPLICATION_CREDENTIALS to a service-account key file path.
GEMINI_USE_VERTEX=false
GEMINI_VERTEX_PROJECT=
GEMINI_VERTEX_LOCATION=us-central1

# ElevenLabs — narration voice (TTS)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# MongoDB — leaderboard + user accounts (falls back to in-memory if unset;
# accounts won't persist across restarts without this).
MONGODB_URI=

# Auth — signs session cookies. MUST be set to a real random value before any
# real deploy; falls back to an insecure dev default (logs a warning) locally.
AUTH_JWT_SECRET=

# Solana — coin/trophy ledger (MockLedger unless USE_REAL_SOLANA=true)
USE_REAL_SOLANA=false
SOLANA_RPC_URL=https://api.devnet.solana.com
# Three keypair files (Solana CLI format), all OUTSIDE version control:
# PATH  = demo player 1's wallet, PATH2 = demo player 2's wallet,
# PATH3 = the house/escrow wallet (holds the pot between match start + end).
SOLANA_KEYPAIR_PATH=
SOLANA_KEYPAIR_PATH2=
SOLANA_KEYPAIR_PATH3=
SOLANA_BET_SOL=0.1
# DEMO ONLY: JSON map of accountId -> keypair file path, for accounts whose
# secret key we hold server-side so a match between two of them moves real SOL
# both ways (escrow in at match start, payout at match end). Populated by
# `npm -w server run seed:demo`. Never do this for a real user's wallet.
SOLANA_DEMO_KEYPAIRS=
