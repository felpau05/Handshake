# ─────────────────────────────────────────────────────────────────────────────
# CUHack2026 — Gamemaster RPS environment variables
# Copy this file to `server/.env` and fill in real values as you wire each service.
# Everything runs on mocks/stubs by default, so the game is playable with NONE of
# these set. Add keys only for the services you're turning "real".
# ─────────────────────────────────────────────────────────────────────────────

# --- Server ---
PORT=3001
# Origin allowed to connect over Socket.IO / CORS during dev (the Vite client).
CLIENT_ORIGIN=http://localhost:5173

# --- Gemini (gamemaster narration + balance twists + image-gen) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# When true, generateStylizedPortrait() returns the original photo unmodified
# (no image-gen call). Flip to false once you're ready to call the image model.
STUB_IMAGE_GEN=true
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# --- ElevenLabs (text-to-speech voice for narration) ---
# When unset, the TTS client returns null audio and the game just shows text.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- MongoDB (leaderboard) ---
# When unset, the server falls back to an in-memory leaderboard so it still runs.
MONGODB_URI=

# --- Solana (coin / trophy ledger) ---
# Leave USE_REAL_SOLANA=false to run on the in-memory MockLedger (recommended for
# the demo). Set true + provide RPC + secret key to settle on devnet.
USE_REAL_SOLANA=false
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_SERVER_SECRET_KEY=
